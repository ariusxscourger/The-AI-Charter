# Band.ai Configuration
BAND_API_KEY=your_band_api_key
BAND_USER_ID=your_band_user_participant_id

# Individual Agent Band API Keys
# Optional: each falls back to BAND_API_KEY if unset.
SECURITY_AGENT_API_KEY=your_security_agent_api_key
ETHICS_AGENT_API_KEY=your_ethics_agent_api_key
LEGAL_AGENT_API_KEY=your_legal_agent_api_key
PRODUCT_AGENT_API_KEY=your_product_agent_api_key
COMPLIANCE_AGENT_API_KEY=your_compliance_agent_api_key

# Individual Agent Band Participant IDs
# Required to invite the agents into real Band rooms.
SECURITY_AGENT_ID=your_security_agent_participant_id
ETHICS_AGENT_ID=your_ethics_agent_participant_id
LEGAL_AGENT_ID=your_legal_agent_participant_id
PRODUCT_AGENT_ID=your_product_agent_participant_id
COMPLIANCE_AGENT_ID=your_compliance_agent_participant_id

# LLM Providers
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=openrouter/auto
FEATHERLESS_API_KEY=your_featherless_key
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=google/gemma-4-31B-it
AIML_API_KEY=your_aiml_key
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=google/gemma-4-31B-it
LLM_PROVIDER=aiml

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_POLL_INTERVAL_MS=3000
NEXT_PUBLIC_TEST="test"

# APP CONFIGURATION
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/charter_db
JWT_SECRET=fallback_jwt_secret_hackathon_2026
